{
  "name": "open-claw-mission-control",
  "private": true,
  "version": "0.1.0",
  "description": "Open Claw Mission Control Dashboard — real-time command center for the 9-agent system.",
  "workspaces": ["client", "server"],
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build && npm --workspace server run build",
    "lint": "npm --workspace client run lint",
    "test": "npm --workspace client run test",
    "e2e": "npm --workspace client run e2e"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
